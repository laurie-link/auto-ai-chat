{
  "manifest_version": 3,
  "name": "AI AutoChat — Brand Visibility",
  "version": "1.0.0",
  "description": "按预设问题访问各 AI 站点，采集回复与引用并保存到本地（Gemini、ChatGPT、Perplexity、Google AI Overview / AI Mode 等）。",
  "permissions": ["storage", "tabs", "downloads", "scripting", "webNavigation", "sidePanel"],
  "host_permissions": [
    "https://dify.aiexplorerxj.top/*",
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://www.google.com/*"
  ],
  "action": {
    "default_title": "AI AutoChat — 打开侧边栏"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/page-keepalive.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/dom-utils.js", "content/gemini.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content/page-keepalive.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content/dom-utils.js", "content/chatgpt.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://www.perplexity.ai/*", "https://perplexity.ai/*"],
      "js": ["content/page-keepalive.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://www.perplexity.ai/*", "https://perplexity.ai/*"],
      "js": ["content/dom-utils.js", "content/perplexity.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["content/google-search.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
